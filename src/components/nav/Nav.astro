---
// ═══════════════════════════════════════════════════════════════════════════
// Nav.astro — 고정 상단 내비게이션
//   로고(∞ 이상한 고리) + 섹션 앵커(스크롤 스파이 = TrackNav 활성 인디케이터)
//   + 이력서 링크 + ThemeSwitcher + LangSwitcher + 모바일 버거 메뉴
//   앵커는 홈 단일 페이지의 섹션 id 를 가리킨다(섹션은 P3-G 등이 채움).
// ═══════════════════════════════════════════════════════════════════════════
import { t, type Locale, type UiKey } from '../../i18n/ui';
import { localeHref } from '../../lib/url';
import ThemeSwitcher from './ThemeSwitcher.astro';
import LangSwitcher from './LangSwitcher.astro';

interface Props {
  locale: Locale;
  /** 반대 로케일 대응 페이지 존재 여부 → LangSwitcher 로 전달(preview/404 는 false) */
  localeAlternate?: boolean;
}
const { locale, localeAlternate = true } = Astro.props;

// UI 사전 키 → 링크 매핑 (하드코딩 카피 금지 — t() 경유).
//   · 홈 섹션 링크: 홈 경로 + 해시(`${home}#philosophy`) — 서브페이지에서 눌러도 홈으로 이동 후 스크롤.
//     (기존 bare hash 는 /research·/dev 등 서브페이지에서 죽은 앵커였음 — S1 수정.)
//   · v4 신규 섹션 체계(순서): #philosophy #works #research(TRIH 피처드) #simulator #timeline #resume #contact.
//   · nav.trih → #research 앵커(홈 피처드 연구), nav.research → /research 독립 페이지 로 구분(라벨 충돌 회피).
//   · '연구'·'개발' 페이지는 홈 섹션이 아니라 독립 페이지 → localeHref 페이지 링크(spy 없음).
//   · spy = 스크롤 스파이용 순수 해시(홈에서만 유효, 섹션 id 와 정확히 일치). 페이지 링크는 spy 없음.
const home = localeHref(locale, '/');
// 위계(tier): 1 = 핵심(프로젝트·경력·연락 + 이력서 버튼) 강조, 2 = 보조(철학·TRIH·시뮬레이터·연구·개발) 약한 톤.
//   · label 오버라이드 = 의미충돌쌍 구분어. 이력↔이력서 → '경력'↔'이력서', 연구↔TRIH → '연구 전체'↔'TRIH'.
//     (신규 문구는 pick 리터럴 ko/en 병행. 나머지 링크는 기존대로 t() 사전 라벨.)
//   · TRIH 진입점 구조 자체는 유지(hold) — 라벨만 명확화.
type NavLink = { key: UiKey; href: string; spy: string | null; tier: 1 | 2; label?: Record<Locale, string> };
const links: NavLink[] = [
  { key: 'nav.philosophy', href: `${home}#philosophy`,           spy: '#philosophy', tier: 2 },
  { key: 'nav.work',       href: `${home}#works`,                spy: '#works',      tier: 1 },
  { key: 'nav.trih',       href: `${home}#research`,             spy: '#research',   tier: 2 },
  { key: 'nav.simulator',  href: `${home}#simulator`,            spy: '#simulator',  tier: 2 },
  { key: 'nav.timeline',   href: `${home}#timeline`,             spy: '#timeline',   tier: 1, label: { ko: '경력', en: 'Career' } },
  { key: 'nav.contact',    href: `${home}#contact`,              spy: '#contact',    tier: 1 },
  { key: 'nav.research',   href: localeHref(locale, '/research'), spy: null,         tier: 2, label: { ko: '연구 전체', en: 'All research' } },
  { key: 'nav.dev',        href: localeHref(locale, '/dev'),      spy: null,         tier: 2 },
];

// 이력서 링크 → 홈 이력서(#resume) 섹션 → 홈 경로 + 해시(서브페이지 대응).
const resumeHref = `${home}#resume`;
const resumeLabel = t(locale, 'nav.resume');
---

<header class="nav" id="nav" data-nav>
  <div class="wrap nav-in">
    <!-- 로고: 이상한 고리(strange loop) — 자기참조 모티프. 이중 링 + ∞ -->
    <a href={home} class="mark" aria-label="Yu Seunghun — home">
      <svg viewBox="0 0 40 40" width="22" height="22" aria-hidden="true" class="mark-svg">
        <circle cx="20" cy="20" r="16" fill="none" stroke="var(--accent)" stroke-width="1.5" />
        <circle cx="20" cy="20" r="10" fill="none" stroke="var(--ink-3)" stroke-width="1" stroke-dasharray="3 3" />
        <text x="20" y="25.5" text-anchor="middle" fill="var(--accent)" font-size="15"
              style="font-family:var(--font-display-en);font-style:italic;">∞</text>
      </svg>
      <b>YU&nbsp;SEUNGHUN</b>
    </a>

    <!-- 데스크톱 앵커 내비 (스크롤 스파이 활성 표시) -->
    <nav class="nav-links" aria-label={locale === 'ko' ? '주요 내비게이션' : 'Primary'}>
      {links.map((l) => (
        <a href={l.href} data-spy={l.spy ?? undefined} data-tier={l.tier}>{l.label ? l.label[locale] : t(locale, l.key)}</a>
      ))}
    </nav>

    <div class="nav-actions">
      <a class="nav-resume" href={resumeHref}>{resumeLabel}</a>
      <LangSwitcher locale={locale} localeAlternate={localeAlternate} />
      <ThemeSwitcher locale={locale} />
      <button class="burger" id="burger" type="button" aria-label={locale === 'ko' ? '메뉴' : 'Menu'} aria-expanded="false" aria-controls="mnav">
        <svg viewBox="0 0 16 16" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
          <path d="M1 4h14M1 8h14M1 12h14" />
        </svg>
      </button>
    </div>
  </div>

  <!-- 모바일 오프캔버스 메뉴 -->
  <nav class="mobile-nav" id="mnav" aria-label={locale === 'ko' ? '모바일 내비게이션' : 'Mobile'}>
    {links.map((l) => (
      <a href={l.href}>{l.label ? l.label[locale] : t(locale, l.key)}</a>
    ))}
    <a href={resumeHref}>{resumeLabel}</a>
  </nav>
</header>

<style>
  .nav {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 90;
    background: color-mix(in srgb, var(--bg) 86%, transparent);
    backdrop-filter: saturate(140%) blur(10px);
    border-bottom: 1px solid transparent;
    transition: border-color var(--dur) var(--ease), background var(--dur) var(--ease);
  }
  .nav.stuck { border-bottom-color: var(--border); }

  .nav-in { display: flex; align-items: center; gap: 20px; height: 62px; }

  .mark { display: inline-flex; align-items: center; gap: 10px; flex-shrink: 0; }
  .mark b { font: 500 var(--fz-xxs) / 1 var(--font-mono); letter-spacing: 0.2em; }
  /* pointer:fine 에서만 로고 링 회전(절제). reduced-motion 게이트는 base.css 전역 규칙. */
  @media (hover: hover) and (pointer: fine) {
    .mark:hover .mark-svg circle:first-of-type { animation: mark-spin 8s linear infinite; transform-origin: 20px 20px; }
  }
  @keyframes mark-spin { to { transform: rotate(360deg); } }

  .nav-links { display: flex; gap: 24px; margin-left: auto; }
  .nav-links a {
    position: relative;
    font: 400 var(--fz-xxs) / 1 var(--font-mono);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-2); /* 판독성 상향: 기본색 ink-3 → ink-2 (초소형 mono·넓은 자간 보정) */
    padding: 6px 0;
    transition: color var(--dur) var(--ease);
  }
  .nav-links a::after {
    content: '';
    position: absolute;
    left: 0; bottom: 0;
    height: 1px; width: 0;
    background: var(--accent);
    transition: width 0.3s var(--ease);
  }
  .nav-links a:hover { color: var(--ink); }
  .nav-links a:hover::after,
  .nav-links a[aria-current='true']::after { width: 100%; }
  .nav-links a[aria-current='true'] { color: var(--ink); }
  /* 위계 톤: 1차 굵게 강조, 2차 옅은 잉크로 약화. 호버·활성은 위 규칙이 var(--ink)로 덮는다. */
  .nav-links a[data-tier='1'] { font-weight: 500; }
  .nav-links a[data-tier='2']:not(:hover):not([aria-current='true']) { color: var(--ink-3); }

  .nav-actions { display: flex; align-items: center; gap: 8px; }
  .nav-resume {
    font: 500 var(--fz-xxs) / 1 var(--font-mono);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-2);
    padding: 9px 14px;
    border: 1px solid var(--border);
    border-radius: 999px;
    transition: color var(--dur) var(--ease), border-color var(--dur) var(--ease);
  }
  .nav-resume:hover { color: var(--ink); border-color: var(--ink-3); }

  .burger { display: none; align-items: center; justify-content: center; width: 34px; height: 34px; border: 1px solid var(--border); border-radius: 999px; color: var(--ink-2); }
  .mobile-nav { display: none; }

  /* 데스크톱에선 앵커 노출, 좁아지면 버거로 접기.
     860→1000px 상향: 861~1000 밴드에서 8링크+이력서+Lang+Theme 밀집, /en 장문 라벨 오버플로 위험 해소. */
  @media (max-width: 1000px) {
    .nav-links, .nav-resume { display: none; }
    .burger { display: inline-flex; }
    .mobile-nav {
      display: none;
      flex-direction: column;
      border-top: 1px solid var(--border);
      background: var(--bg);
    }
    .mobile-nav.open { display: flex; }
    .mobile-nav a {
      padding: 14px var(--gutter);
      border-bottom: 1px solid var(--border-soft);
      font: 400 var(--fz-xxs) / 1 var(--font-mono);
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--ink-2);
    }
    .mobile-nav a:hover { color: var(--ink); }
  }

  /* 터치타깃 확대 (≤560px): 34px 시각 원은 유지하고 투명 ::before 로 탭영역만 ~42px 확대.
     상단 3컨트롤(버거·테마·언어) 간격도 소폭 넓혀 인접 오탭 방지. 라이트 시각 불변. */
  @media (max-width: 560px) {
    .nav-actions { gap: 12px; }
    .burger { position: relative; }
    .burger::before { content: ''; position: absolute; inset: -4px; border-radius: inherit; }
  }

  @media print { .nav { display: none; } }
</style>

<script>
  // ── 스크롤 시 하단 헤어라인 표시(stuck) ──
  const nav = document.getElementById('nav');
  if (nav) {
    const onScroll = () => nav.classList.toggle('stuck', window.scrollY > 24);
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  // ── 버거 토글 + 오프캔버스 포커스 관리(키보드/AT) ──
  //   · 열 때: 첫 메뉴 링크로 포커스 이동
  //   · Escape: 닫고 버거로 포커스 반환
  //   · Tab: [버거 + 메뉴 링크] 안에서 순환(트랩) → 오버레이 뒤 페이지로 탭 새는 문제 차단
  //   · keydown 리스너는 열림 동안만 바인딩, 닫힘 시 제거(no-op화)
  const burger = document.getElementById('burger');
  const mnav = document.getElementById('mnav');
  if (burger && mnav) {
    const menuLinks = () => Array.from(mnav.querySelectorAll<HTMLAnchorElement>('a'));

    // 트랩 대상: 버거(토글) + 메뉴 링크들.
    function onKeydown(e: KeyboardEvent) {
      if (e.key === 'Escape') { closeMenu(); return; }
      if (e.key !== 'Tab') return;
      const els: HTMLElement[] = [burger as HTMLElement, ...menuLinks()];
      if (els.length < 2) return;
      const first = els[0];
      const last = els[els.length - 1];
      const active = document.activeElement as HTMLElement | null;
      if (!active || !els.includes(active)) { e.preventDefault(); first.focus(); return; }
      if (e.shiftKey && active === first) { e.preventDefault(); last.focus(); }
      else if (!e.shiftKey && active === last) { e.preventDefault(); first.focus(); }
    }

    function openMenu() {
      if (!mnav) return;
      mnav.classList.add('open');
      burger!.setAttribute('aria-expanded', 'true');
      document.addEventListener('keydown', onKeydown);
      menuLinks()[0]?.focus();
    }
    function closeMenu(returnFocus = true) {
      if (!mnav || !mnav.classList.contains('open')) return;
      mnav.classList.remove('open');
      burger!.setAttribute('aria-expanded', 'false');
      document.removeEventListener('keydown', onKeydown);
      if (returnFocus) burger!.focus();
    }

    burger.addEventListener('click', () => {
      if (mnav.classList.contains('open')) closeMenu();
      else openMenu();
    });
    // 링크 선택 시 닫기(기존 동작 유지) — 포커스는 이동 대상 앵커로 자연 이동하므로 반환하지 않음.
    menuLinks().forEach((a) => a.addEventListener('click', () => closeMenu(false)));
  }

  // ── 스크롤 스파이(TrackNav 활성 인디케이터) — 항상 정확히 1개만 활성 ──
  //   밴드(-45%~-50%)에 걸친 섹션 중 intersectionRatio 최대 1개만 aria-current=true, 나머지는 명시적 false.
  //   걸린 섹션이 없으면(최상·최하단 등) 밴드 중심선 최근접 섹션으로 폴백 → 무활성·이중활성·최하단누락 해소.
  const spyLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('[data-spy]'));
  const targets = spyLinks
    .map((a) => document.querySelector<HTMLElement>(a.getAttribute('data-spy') || ''))
    .filter((el): el is HTMLElement => !!el);

  if (targets.length) {
    const ratios = new Map<Element, number>();
    targets.forEach((el) => ratios.set(el, 0));

    // 정확히 1개만 활성: 대상 링크만 true, 나머지는 명시적 false 초기화.
    const setActive = (el: Element | null) => {
      const id = el ? '#' + el.id : '';
      spyLinks.forEach((a) => a.setAttribute('aria-current', String(a.getAttribute('data-spy') === id)));
    };

    // 밴드 중심선(뷰포트 상단 40% 지점) 최근접 섹션 — 밴드에 걸린 게 없을 때 폴백.
    const nearestToBand = (): Element | null => {
      const line = window.innerHeight * 0.4;
      let best: Element | null = null;
      let bestDist = Infinity;
      for (const el of targets) {
        const r = el.getBoundingClientRect();
        const dist = r.top <= line && r.bottom >= line ? 0 : Math.min(Math.abs(r.top - line), Math.abs(r.bottom - line));
        if (dist < bestDist) { bestDist = dist; best = el; }
      }
      return best;
    };

    // 밴드에 걸린 섹션 중 ratio 최대를 채택, 없으면 폴백 → 언제나 1개 활성.
    const resolve = () => {
      let best: Element | null = null;
      let bestRatio = 0;
      ratios.forEach((ratio, el) => { if (ratio > bestRatio) { bestRatio = ratio; best = el; } });
      setActive(best ?? nearestToBand());
    };

    const spy = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => ratios.set(e.target, e.isIntersecting ? e.intersectionRatio : 0));
        resolve();
      },
      { rootMargin: '-45% 0px -50% 0px', threshold: [0, 0.25, 0.5] }
    );
    targets.forEach((el) => spy.observe(el));
    resolve(); // 초기 1개 활성 보장(스크롤 전)
  }
</script>
