---
// ═══════════════════════════════════════════════════════════════════════════
// TrihInspector.astro — TRIH 4노드 인스펙터 (island, 바닐라 TS)
//   로직 원본: _reference/index_v2_live.html reh-node showRehDetail (L2120-2150) + v3.1 스왑
//   · trih 컬렉션 4건을 props(items)로 받아 노드 클릭/키보드(Enter·Space)로 상세 스왑.
//   · 각 노드 <g role=button tabindex=0> — 마우스·키보드 접근. 상세는 aria-live 패널.
//   · 색·라벨 전량 토큰화. locale 로 ko/en 문자열 서버 확정.
// props:
//   items  : trih 컬렉션 엔트리 배열 (getCollection('trih')) — 순서 무관, no 로 정렬.
//   locale : 'ko' | 'en'
// ═══════════════════════════════════════════════════════════════════════════
import type { Locale } from '../../i18n/ui';
interface Props { items: any[]; locale?: Locale }
const { items, locale = 'ko' as Locale } = Astro.props;
const ko = locale === 'ko';

// 노드 좌표·색축 (viewBox 500×500) — key 로 매핑
const POS: Record<string, { cx: number; cy: number; axis: 'gold' | 'violet'; sec: string }> = {
  escher:      { cx: 250, cy: 80,  axis: 'gold',   sec: '§3' },
  bach:        { cx: 420, cy: 250, axis: 'gold',   sec: '§4' },
  godel:       { cx: 250, cy: 420, axis: 'violet', sec: '§5' },
  transformer: { cx: 80,  cy: 250, axis: 'violet', sec: '§6' },
};
const stroke = (axis: string) => (axis === 'gold' ? 'var(--accent)' : 'var(--violet, #6b5cc4)');

// 노드별 미니 글리프 — 원점(0,0) 기준 소형 도형(약 ±9). col 은 축 색 토큰.
//   escher: 불가능 삼각형(테셀레이션) · bach: 8분음표 · godel: 턴스타일 ⊢ · transformer: 어텐션 격자
const glyph = (key: string, col: string): string => {
  switch (key) {
    case 'escher':
      return `<path d="M0,-8 L7,5 L-7,5 Z" fill="none" stroke="${col}" stroke-width="1.2" stroke-linejoin="round"/>`
           + `<path d="M0,-3 L3.5,3.5 L-3.5,3.5 Z" fill="none" stroke="${col}" stroke-width="0.9" opacity="0.7"/>`;
    case 'bach':
      return `<path d="M-1,4 L-1,-7 L5,-9" fill="none" stroke="${col}" stroke-width="1.2" stroke-linecap="round"/>`
           + `<ellipse cx="-3.4" cy="4.2" rx="3" ry="2.2" fill="${col}" transform="rotate(-20 -3.4 4.2)"/>`;
    case 'godel':
      return `<path d="M-5,-7 V7 M-5,0 H6" fill="none" stroke="${col}" stroke-width="1.3" stroke-linecap="round"/>`
           + `<circle cx="6" cy="0" r="1.4" fill="${col}"/>`;
    case 'transformer':
      return `<g stroke="${col}" stroke-width="0.8" opacity="0.85">`
           + `<line x1="-6" y1="-5" x2="6" y2="5"/><line x1="6" y1="-5" x2="-6" y2="5"/>`
           + `<line x1="0" y1="-5" x2="-6" y2="5"/><line x1="0" y1="-5" x2="6" y2="5"/></g>`
           + `<g fill="${col}"><circle cx="-6" cy="-5" r="1.7"/><circle cx="0" cy="-5" r="1.7"/><circle cx="6" cy="-5" r="1.7"/>`
           + `<circle cx="-6" cy="5" r="1.7"/><circle cx="6" cy="5" r="1.7"/></g>`;
    default:
      return '';
  }
};

// 엔트리 정규화(.data 래핑 대응) + 로케일 확정 + no 정렬
const L = (v: any) => (typeof v === 'string' ? v : ko ? v?.ko : v?.en) ?? '';
const nodes = items
  .map((it) => (it?.data ?? it))
  .filter((d) => d && POS[d.key])
  .sort((a, b) => (a.no ?? 0) - (b.no ?? 0))
  .map((d) => ({
    key: d.key as string,
    domain: L(d.domain),
    figure: L(d.figure),
    mechanism: L(d.mechanism),
    detail: L(d.detail),
    tag: d.tag as string,
    ...POS[d.key],
  }));

// 노드 외곽(다이어그램 중심에서 바깥으로) SEC 라벨 좌표 + 글리프 마크업 부착
const nodesX = nodes.map((n) => {
  const dx = n.cx - 250, dy = n.cy - 250;
  const len = Math.hypot(dx, dy) || 1;
  return {
    ...n,
    col: stroke(n.axis),
    secX: 250 + (dx / len) * 54,
    secY: 250 + (dy / len) * 54 + 3,
    glyph: glyph(n.key, stroke(n.axis)),
  };
});

const first = nodes[0];
const uid = 'ti-' + Math.random().toString(36).slice(2, 8);
const hint = ko ? '노드를 클릭하세요' : 'CLICK A NODE';
const detailData = Object.fromEntries(nodes.map((n) => [n.key, { domain: n.domain, figure: n.figure, mechanism: n.mechanism, detail: n.detail, tag: n.tag, sec: n.sec }]));
---

<div class="trih-inspector" data-trih>
  <!-- 좌: 4노드 다이어그램(클릭·키보드) -->
  <div class="ti-map">
    <svg viewBox="0 0 500 500" class="ti-svg" role="group" aria-label={ko ? 'TRIH 4영역 노드 — 클릭하면 오른쪽에 상세가 표시됩니다' : 'TRIH four domains — click a node to view detail on the right'}>
      <defs>
        <linearGradient id={`${uid}-g`} x1="0" x2="1" y1="0" y2="1">
          <stop offset="0%" style="stop-color:var(--accent)" />
          <stop offset="100%" style="stop-color:var(--violet, #6b5cc4)" />
        </linearGradient>
        <radialGradient id={`${uid}-core`} cx="50%" cy="50%" r="50%">
          <stop offset="0%" style="stop-color:var(--accent-tint);stop-opacity:0.55" />
          <stop offset="100%" style="stop-color:var(--accent-tint);stop-opacity:0" />
        </radialGradient>
        <marker id={`${uid}-arrow`} viewBox="0 0 12 12" refX="9" refY="6" markerWidth="5.5" markerHeight="5.5" orient="auto-start-reverse">
          <path d="M 0,0 L 12,6 L 0,12 z" fill="var(--accent)" />
        </marker>
        <filter id={`${uid}-glow`} x="-60%" y="-60%" width="220%" height="220%">
          <feGaussianBlur stdDeviation="4" result="b" />
          <feMerge><feMergeNode in="b" /><feMergeNode in="SourceGraphic" /></feMerge>
        </filter>
      </defs>

      {/* 배경 가이드 링 */}
      <g class="ti-guides" fill="none">
        <circle cx="250" cy="250" r="190" stroke="var(--border)" stroke-width="1" stroke-dasharray="2 7" />
        <circle cx="250" cy="250" r="130" stroke="var(--border-soft, var(--border))" stroke-width="1" />
      </g>

      {/* 교차 대각(십자) 보조선 */}
      <g class="ti-cross" stroke="var(--accent)" stroke-width="0.8" stroke-dasharray="1 5">
        <line x1="250" y1="90" x2="250" y2="410" />
        <line x1="90" y1="250" x2="410" y2="250" />
      </g>

      {/* 동형 연결 경로 — 방향성 순환(에셔→바흐→괴델→트랜스포머) */}
      <g class="ti-links" opacity="0.6" stroke-linecap="round" fill="none" stroke={`url(#${uid}-g)`} stroke-width="1.3" stroke-dasharray="4 6">
        <path d="M 285,105 Q 372,150 405,215" marker-end={`url(#${uid}-arrow)`} />
        <path d="M 405,285 Q 372,350 285,395" marker-end={`url(#${uid}-arrow)`} />
        <path d="M 215,395 Q 128,350 95,285" marker-end={`url(#${uid}-arrow)`} />
        <path d="M 95,215 Q 128,150 215,105" marker-end={`url(#${uid}-arrow)`} />
      </g>

      {/* 자기참조 코어 — 광채 · 이중 링 · 회전 점선 · 스트레인지 루프 */}
      <g class="ti-core">
        <circle cx="250" cy="250" r="72" fill={`url(#${uid}-core)`} />
        <circle cx="250" cy="250" r="54" fill="var(--bg)" stroke="var(--accent)" stroke-width="1.6" />
        <circle cx="250" cy="250" r="47" fill="none" stroke="var(--accent)" stroke-width="0.6" opacity="0.55" />
        <circle cx="250" cy="250" r="42" fill="none" stroke="var(--accent)" stroke-width="0.6" stroke-dasharray="2 4" class="ti-spin" style="transform-origin:250px 250px" />
        <path class="ti-loop" d="M 232,203 Q 262,188 274,214" fill="none" stroke="var(--accent)" stroke-width="1.1" opacity="0.7" marker-end={`url(#${uid}-arrow)`} />
        <text x="250" y="247" text-anchor="middle" fill="var(--accent)" font-size="15"
              style="font-family:var(--font-display-en);font-style:italic;letter-spacing:1px">TRIH</text>
        <text x="250" y="262" text-anchor="middle" fill="var(--ink-2)" font-size="7" letter-spacing="1.6">RECURSIVE</text>
        <text x="250" y="272" text-anchor="middle" fill="var(--ink-3)" font-size="7" letter-spacing="1.6">EMERGENCE</text>
      </g>

      {/* 4 노드 (버튼) — 이중 테두리 · 펄스 · 미니 글리프 · SEC 라벨 */}
      {nodesX.map((n, i) => (
        <g class="ti-node" role="button" tabindex="0" data-key={n.key}
           aria-pressed={n.key === first?.key ? 'true' : 'false'}
           aria-label={`${n.domain} · ${n.figure}`}>
          <circle cx={n.cx} cy={n.cy} r="40" class="ti-halo" fill="none" stroke={n.col} stroke-width="2" filter={`url(#${uid}-glow)`} />
          <circle cx={n.cx} cy={n.cy} r="40" class="ti-pulse" fill="none" stroke={n.col} stroke-width="1.4" style={`transform-origin:${n.cx}px ${n.cy}px;animation-delay:${(i * 0.85).toFixed(2)}s`} />
          <circle cx={n.cx} cy={n.cy} r="40" class="ti-ring" fill="var(--surface)" stroke={n.col} stroke-width="2" />
          <circle cx={n.cx} cy={n.cy} r="33" class="ti-ring-inner" fill="none" stroke={n.col} stroke-width="0.7" stroke-dasharray="2 4" opacity="0.5" />
          <g class="ti-glyph" transform={`translate(${n.cx} ${n.cy - 21})`} set:html={n.glyph} />
          <text x={n.cx} y={n.cy - 3} text-anchor="middle" fill={n.col} font-size="10"
                style="font-family:var(--font-display-en);letter-spacing:1.5px">{n.domain}</text>
          <text x={n.cx} y={n.cy + 13} text-anchor="middle" fill="var(--ink)" font-size="11"
                style="font-family:var(--font-body);font-weight:500">{n.figure}</text>
          <text x={n.secX} y={n.secY} text-anchor="middle" fill="var(--ink-3)" font-size="8.5"
                style="font-family:var(--font-mono);letter-spacing:1px">SEC {n.sec}</text>
        </g>
      ))}
    </svg>
    <span class="ti-hint" aria-hidden="true">{hint} →</span>
    <span class="ti-mark" aria-hidden="true">TRIH-CORE</span>
  </div>

  <!-- 우: 상세 인스펙터 (id 는 uid 프리픽스로 인스턴스 고유 — SVG defs 와 동일 패턴) -->
  <div class="ti-detail" id={`${uid}-detail`} aria-live="polite">
    <span class="ti-tag" id={`${uid}-tag`}>{first?.tag}</span>
    <h3 class="ti-title" id={`${uid}-title`}>{first?.domain} · {first?.figure}</h3>
    <p class="ti-mech" id={`${uid}-mech`}>{first?.mechanism}</p>
    <p class="ti-body" id={`${uid}-body`}>{first?.detail}</p>
    <span class="ti-sec" id={`${uid}-sec`}>SEC {first?.sec}</span>
  </div>

  <script is:inline type="application/json" id={`${uid}-data`} data-trih-json set:html={JSON.stringify(detailData)} />
</div>

<style>
  .trih-inspector {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(20px, 4vw, 48px);
    align-items: center;
  }
  .ti-map { position: relative; }
  .ti-svg { display: block; width: 100%; height: auto; }
  .ti-hint,
  .ti-mark {
    position: absolute;
    font: 400 var(--fz-xxs) / 1 var(--font-mono);
    letter-spacing: 0.16em; text-transform: uppercase; color: var(--ink-3);
    user-select: none; pointer-events: none;
  }
  .ti-hint { top: 6px; left: 6px; }
  .ti-mark { bottom: 6px; right: 6px; opacity: 0.7; }

  /* 배경 보조 요소 — 은은하게 */
  .ti-guides { opacity: 0.35; }
  .ti-cross  { opacity: 0.22; }
  .ti-loop   { pointer-events: none; }

  .ti-node { cursor: pointer; }
  .ti-node .ti-ring,
  .ti-node .ti-ring-inner,
  .ti-node .ti-glyph { transition: stroke-width var(--dur) var(--ease), opacity var(--dur) var(--ease); }

  /* 글로우 헤일로 — 평소 숨김, 호버·활성 시 점등 */
  .ti-node .ti-halo { opacity: 0; transition: opacity var(--dur) var(--ease); pointer-events: none; }
  .ti-node:hover .ti-halo { opacity: 0.4; }
  .ti-node[aria-pressed='true'] .ti-halo { opacity: 0.85; }

  .ti-node .ti-glyph { opacity: 0.7; }
  .ti-node:hover .ti-glyph,
  .ti-node[aria-pressed='true'] .ti-glyph { opacity: 1; }

  /* 활성 노드 강조 — 외곽 굵게 · 내부 링 실선화 */
  .ti-node[aria-pressed='true'] .ti-ring { stroke-width: 3.2; }
  .ti-node[aria-pressed='true'] .ti-ring-inner { opacity: 0.9; stroke-dasharray: none; stroke-width: 1; }

  .ti-node:focus-visible { outline: none; }
  .ti-node:focus-visible .ti-ring { stroke-dasharray: 5 3; }

  /* 펄스 링 — 노드마다 확장·소멸 반복 */
  .ti-pulse { opacity: 0; pointer-events: none; animation: ti-pulse 3.4s var(--ease-expo) infinite; }
  .ti-node[aria-pressed='true'] .ti-pulse { animation-duration: 2.2s; }
  @keyframes ti-pulse {
    0%   { transform: scale(1);    opacity: 0.5; }
    70%  { opacity: 0; }
    100% { transform: scale(1.34); opacity: 0; }
  }

  .ti-spin { animation: ti-rot 26s linear infinite; }
  @keyframes ti-rot { to { transform: rotate(360deg); } }

  .ti-detail {
    padding: clamp(20px, 3vw, 30px);
    border: 1px solid var(--border);
    border-radius: 14px;
    background: var(--surface);
    min-height: 260px;
    transition: opacity 0.22s var(--ease);
  }
  .ti-tag {
    display: inline-block;
    font: 400 var(--fz-xxs) / 1 var(--font-mono);
    letter-spacing: 0.14em; text-transform: uppercase; color: var(--accent);
    padding: 5px 10px; border: 1px solid var(--accent-tint); border-radius: 999px; margin-bottom: 14px;
  }
  .ti-title { font: 600 var(--fz-h3) / 1.2 var(--font-display); color: var(--ink); margin-bottom: 8px; }
  .ti-mech { font-size: var(--fz-sm); color: var(--accent); margin-bottom: 14px; }
  .ti-body { font-size: var(--fz-sm); line-height: 1.75; color: var(--ink-2); }
  .ti-sec {
    display: block; margin-top: 16px;
    font: 400 var(--fz-xxs) / 1 var(--font-mono); letter-spacing: 0.14em; color: var(--ink-3);
  }

  @media (max-width: 860px) {
    .trih-inspector { grid-template-columns: 1fr; }
  }
  @media (prefers-reduced-motion: reduce) {
    .ti-spin { animation: none !important; }
    .ti-pulse { animation: none !important; opacity: 0 !important; }
    .ti-detail { transition: none; }
  }
</style>

<script>
  // ── TRIH 노드 인스펙터 상호작용 ──
  type Detail = { domain: string; figure: string; mechanism: string; detail: string; tag: string; sec: string };
  const root = document.querySelector<HTMLElement>('[data-trih]');
  const json = root?.querySelector('[data-trih-json]');
  if (root && json?.textContent) {
    const DATA = JSON.parse(json.textContent) as Record<string, Detail>;
    // id 는 인스턴스 고유(uid 프리픽스)이므로 루트 내부에서 클래스로 스코프 조회 (인스턴스당 각 1개)
    const panel = root.querySelector<HTMLElement>('.ti-detail');
    const tag = root.querySelector<HTMLElement>('.ti-tag');
    const title = root.querySelector<HTMLElement>('.ti-title');
    const mech = root.querySelector<HTMLElement>('.ti-mech');
    const body = root.querySelector<HTMLElement>('.ti-body');
    const sec = root.querySelector<HTMLElement>('.ti-sec');
    const nodes = Array.from(root.querySelectorAll<SVGGElement>('.ti-node'));

    // 동작 축소 선호 감지 (라이브 반영 — .matches 를 호출 시점에 조회)
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
    // opacity dip 후 스왑 지연 — CSS .ti-detail transition(0.22s)과 일치 (하드코딩 제거)
    const SWAP_MS = 220;

    // 상세 5필드를 한 동기 블록에서 갱신 → aria-live 는 1회만 안내 (이중안내 방지)
    const applyDetail = (d: Detail) => {
      if (tag) tag.textContent = d.tag;
      if (title) title.textContent = `${d.domain} · ${d.figure}`;
      if (mech) mech.textContent = d.mechanism;
      if (body) body.textContent = d.detail;
      if (sec) sec.textContent = `SEC ${d.sec}`;
    };

    const show = (key: string) => {
      const d = DATA[key];
      if (!d || !panel) return;
      nodes.forEach((n) => n.setAttribute('aria-pressed', String(n.dataset.key === key)));
      if (reduceMotion.matches) {
        // 축소 모드: opacity dip 생략, 즉시 스왑 (0ms)
        applyDetail(d);
        return;
      }
      // 일반 모드: opacity dip → CSS transition 과 일치하는 지연 후 스왑·복귀
      panel.style.opacity = '0.35';
      window.setTimeout(() => {
        applyDetail(d);
        panel.style.opacity = '1';
      }, SWAP_MS);
    };

    nodes.forEach((n) => {
      const key = n.dataset.key!;
      n.addEventListener('click', () => show(key));
      n.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); show(key); }
      });
    });
  }
</script>
