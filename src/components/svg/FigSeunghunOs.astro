---
// FigSeunghunOs.astro — 프로젝트 figure: SEUNGHUN OS (지식 그래프 메시)
//   출처 패턴: _reference/index_v2_live.html L1084-1116. 색 전량 토큰화, aria-hidden.
//   ※ 노트 수치는 facts.json(SOS-01) SSOT 전용 — 도판에 하드코딩하지 않음(중립 라벨).
interface Props { class?: string }
const { class: className = '' } = Astro.props;
const uid = 'fs-' + Math.random().toString(36).slice(2, 8);
---
<svg viewBox="0 0 400 300" class={`pf-fig ${className}`} aria-hidden="true" focusable="false" preserveAspectRatio="xMidYMid slice">
  <defs>
    <pattern id={`${uid}-grid`} width="30" height="30" patternUnits="userSpaceOnUse">
      <rect width="30" height="30" fill="none" stroke="var(--accent)" stroke-width="0.4" opacity="0.35" />
    </pattern>
  </defs>
  <rect width="400" height="300" fill="var(--surface)" />
  <rect width="400" height="300" fill={`url(#${uid}-grid)`} />
  {/* 지식 그래프 메시 */}
  <g stroke="var(--accent)" stroke-width="0.5" opacity="0.5">
    <line x1="80" y1="80" x2="160" y2="100" /><line x1="160" y1="100" x2="240" y2="70" />
    <line x1="240" y1="70" x2="320" y2="120" /><line x1="160" y1="100" x2="200" y2="200" />
    <line x1="100" y1="180" x2="200" y2="200" /><line x1="200" y1="200" x2="290" y2="200" />
    <line x1="200" y1="200" x2="150" y2="240" /><line x1="150" y1="240" x2="270" y2="250" />
    <line x1="290" y1="200" x2="270" y2="250" /><line x1="320" y1="120" x2="290" y2="200" />
  </g>
  <g opacity="0.7">
    <circle cx="80" cy="80" r="3" fill="var(--accent)" /><circle cx="160" cy="100" r="4" fill="var(--violet, #6b5cc4)" />
    <circle cx="240" cy="70" r="3" fill="var(--accent)" /><circle cx="320" cy="120" r="5" fill="var(--violet, #6b5cc4)" />
    <circle cx="100" cy="180" r="4" fill="var(--violet, #6b5cc4)" /><circle cx="200" cy="200" r="5" fill="var(--accent)" />
    <circle cx="290" cy="200" r="3" fill="var(--accent)" /><circle cx="150" cy="240" r="4" fill="var(--violet, #6b5cc4)" />
    <circle cx="270" cy="250" r="3" fill="var(--accent)" />
  </g>
  <text x="20" y="290" fill="var(--accent)" font-size="9" opacity="0.6"
        style="font-family:var(--font-mono);letter-spacing:2px">ontology · PARA · knowledge&nbsp;graph</text>
</svg>
<style>.pf-fig{display:block;width:100%;height:100%}</style>
