---
// ═══════════════════════════════════════════════════════════════════════════
// StrangeLoop.astro — 회전 링(이상한 고리) 장식 그래픽
//   출처 패턴: _reference/index_v2_live.html L324-347, L418-482 (rotating rings + figure-8)
//   · 하드코딩 색(#806832 gold / #4a3d96 violet) → var(--accent) / var(--violet,폴백) 토큰화
//   · 순수 장식(aria-hidden) — 의미 전달 없음. JS 0, CSS @keyframes 회전만.
//   · 모든 회전은 prefers-reduced-motion 게이트(스펙 §0 절대 규칙).
// props:
//   variant : 'hero' (라벨 없는 figure-8 + 동심원, 기본) | 'orbit' (좌하단 타원 궤도)
//   class   : 배치용 유틸 클래스 패스스루
// ═══════════════════════════════════════════════════════════════════════════
interface Props {
  variant?: 'hero' | 'orbit';
  class?: string;
}
const { variant = 'hero', class: className = '' } = Astro.props;
// 고유 gradient id (한 페이지에 다중 인스턴스 충돌 방지)
const uid = 'sl-' + Math.random().toString(36).slice(2, 8);
---

{variant === 'hero' && (
  <svg viewBox="0 0 400 400" class={`strange-loop ${className}`} aria-hidden="true" focusable="false">
    <defs>
      <linearGradient id={`${uid}-g`} x1="0" x2="1" y1="0" y2="1">
        <stop offset="0%" style="stop-color:var(--accent)" />
        <stop offset="100%" style="stop-color:var(--violet, #6b5cc4)" />
      </linearGradient>
      <radialGradient id={`${uid}-c`}>
        <stop offset="0%" style="stop-color:var(--accent);stop-opacity:.28" />
        <stop offset="100%" style="stop-color:var(--accent);stop-opacity:0" />
      </radialGradient>
    </defs>

    {/* 중심 글로우 */}
    <circle cx="200" cy="200" r="180" fill={`url(#${uid}-c)`} />

    {/* 바깥 점선 링 — 정방향 회전 */}
    <g class="sl-spin" style="transform-origin:200px 200px">
      <circle cx="200" cy="200" r="170" fill="none" stroke="var(--accent)" stroke-width="0.8" stroke-dasharray="2 8" opacity="0.55" />
    </g>

    {/* 이상한 고리 본체(figure-8 계열) — 역방향 회전 */}
    <g class="sl-spin-rev" style="transform-origin:200px 200px">
      <path d="M 200,80 C 280,80 320,140 320,200 C 320,260 280,320 200,320 C 120,320 80,260 80,200 C 80,140 120,80 200,80 Z"
            fill="none" stroke={`url(#${uid}-g)`} stroke-width="1.5" class="sl-loop" />
      <path d="M 200,120 C 260,120 280,160 280,200 C 280,240 260,280 200,280 C 140,280 120,240 120,200 C 120,160 140,120 200,120 Z"
            fill="none" stroke="var(--accent)" stroke-width="0.8" opacity="0.55" />
    </g>

    {/* 자기참조 코어 */}
    <circle cx="200" cy="200" r="34" fill="var(--bg)" stroke="var(--accent)" stroke-width="1.5" />
    <text x="200" y="197" text-anchor="middle" fill="var(--accent)" font-size="11"
          style="font-family:var(--font-display-en);font-style:italic;letter-spacing:1px">TRIH</text>
    <text x="200" y="212" text-anchor="middle" fill="var(--ink-3)" font-size="6" letter-spacing="1.5">RECURSIVE</text>
  </svg>
)}

{variant === 'orbit' && (
  <svg viewBox="0 0 400 400" class={`strange-loop ${className}`} aria-hidden="true" focusable="false">
    <g class="sl-spin-rev" style="transform-origin:200px 200px">
      <ellipse cx="200" cy="200" rx="180" ry="90" fill="none" stroke="var(--accent)" stroke-width="1.5" />
      <ellipse cx="200" cy="200" rx="90" ry="180" fill="none" stroke="var(--violet, #6b5cc4)" stroke-width="1" />
    </g>
  </svg>
)}

<style>
  .strange-loop { display: block; width: 100%; height: auto; }

  /* 회전 링 — 자기참조 모티프. 정방향/역방향 이중 속도. */
  .sl-spin     { animation: sl-rot 22s linear infinite; }
  .sl-spin-rev { animation: sl-rot 30s linear infinite reverse; }
  @keyframes sl-rot { to { transform: rotate(360deg); } }

  /* 이상한 고리 대시 흐름 */
  .sl-loop { stroke-dasharray: 4 6; animation: sl-dash 30s linear infinite; }
  @keyframes sl-dash { to { stroke-dashoffset: -1000; } }

  /* 절대 규칙: 모션 최소화 선호 시 전 회전 정지 */
  @media (prefers-reduced-motion: reduce) {
    .sl-spin, .sl-spin-rev, .sl-loop { animation: none !important; }
  }
</style>
