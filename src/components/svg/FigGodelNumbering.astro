---
// FigGodelNumbering.astro — TRIH §5 괴델 넘버링 구조도
//   기호열(¬ ∨ ∀) → 소수 지수 인코딩(2^a·3^b·5^c) → 단일 수 G → 다시 명제로 (자기지시 고리).
//   패턴 준수: viewBox 0 0 400 300 · 색 전량 var() 토큰 · uid 프리픽스 충돌 방지.
interface Props { class?: string }
const { class: className = '' } = Astro.props;
const uid = 'fgn-' + Math.random().toString(36).slice(2, 8);
---
<svg viewBox="0 0 400 300" class={`pf-fig ${className}`} role="img"
     aria-label="Gödel numbering — 기호열이 소수 지수로 인코딩되어 하나의 수 G가 되고, 그 수가 다시 자신을 지시하는 명제로 되돌아오는 자기지시 고리"
     focusable="false" preserveAspectRatio="xMidYMid slice">
  <defs>
    <linearGradient id={`${uid}-g`} x1="0" x2="1" y1="0" y2="1">
      <stop offset="0%" style="stop-color:var(--accent);stop-opacity:.13" />
      <stop offset="100%" style="stop-color:var(--violet, #6b5cc4);stop-opacity:.09" />
    </linearGradient>
    <marker id={`${uid}-ar`} viewBox="0 0 10 10" refX="8" refY="5" markerWidth="7" markerHeight="7" orient="auto">
      <path d="M 0,0 L 10,5 L 0,10 z" fill="var(--accent)" />
    </marker>
  </defs>
  <rect width="400" height="300" fill="var(--surface)" />
  <rect width="400" height="300" fill={`url(#${uid}-g)`} />

  {/* Stage 1 — 기호열 */}
  <rect x="46" y="86" width="96" height="52" rx="4" fill="none" stroke="var(--accent)" stroke-width="1.4" />
  <text x="94" y="108" text-anchor="middle" fill="var(--ink)" font-size="20"
        style="font-family:var(--font-body);letter-spacing:6px">¬∨∀</text>
  <text x="94" y="128" text-anchor="middle" fill="var(--ink-3)" font-size="8"
        style="font-family:var(--font-mono);letter-spacing:1.5px">symbols</text>

  {/* → 인코딩 */}
  <line x1="146" y1="112" x2="186" y2="112" stroke="var(--accent)" stroke-width="1.4"
        marker-end={`url(#${uid}-ar)`} opacity="0.85" />

  {/* Stage 2 — 소수 지수 인코딩 */}
  <rect x="190" y="86" width="120" height="52" rx="4" fill="none" stroke="var(--violet, #6b5cc4)" stroke-width="1.4" />
  <text x="250" y="112" text-anchor="middle" fill="var(--violet, #6b5cc4)" font-size="14"
        style="font-family:var(--font-mono);letter-spacing:0.5px">2ᵃ·3ᵇ·5ᶜ</text>
  <text x="250" y="128" text-anchor="middle" fill="var(--ink-3)" font-size="8"
        style="font-family:var(--font-mono);letter-spacing:1.5px">prime encoding</text>

  {/* → 단일 수 G */}
  <line x1="314" y1="112" x2="352" y2="112" stroke="var(--accent)" stroke-width="1.4"
        marker-end={`url(#${uid}-ar)`} opacity="0.85" />
  <circle cx="366" cy="112" r="18" fill="none" stroke="var(--accent)" stroke-width="1.6" />
  <text x="366" y="118" text-anchor="middle" fill="var(--accent)" font-size="20"
        style="font-family:var(--font-display-en);font-style:italic;font-weight:600">G</text>

  {/* 자기지시 고리 — G → 다시 명제로 (아래를 돌아 기호열로 복귀) */}
  <path d="M 366,132 C 366,210 200,232 94,200 C 60,190 62,158 78,142"
        fill="none" stroke="var(--accent)" stroke-width="1.3" stroke-dasharray="4 5"
        marker-end={`url(#${uid}-ar)`} opacity="0.7" class="fgn-loop" />
  <text x="200" y="228" text-anchor="middle" fill="var(--accent)" font-size="9.5" opacity="0.85"
        style="font-family:var(--font-display-en);font-style:italic;letter-spacing:1px">the number names its own proposition</text>

  <text x="200" y="266" text-anchor="middle" fill="var(--ink-3)" font-size="8.5" opacity="0.75"
        style="font-family:var(--font-mono);letter-spacing:1.5px">¬ ∨ ∀  →  2ᵃ·3ᵇ·5ᶜ  →  G</text>
</svg>
<style>
  .pf-fig{display:block;width:100%;height:100%}
  .fgn-loop{animation:fgn-dash 26s linear infinite}
  @keyframes fgn-dash{to{stroke-dashoffset:-900}}
  @media (prefers-reduced-motion: reduce){.fgn-loop{animation:none !important}}
</style>
