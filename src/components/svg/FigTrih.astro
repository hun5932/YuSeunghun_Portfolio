---
// FigTrih.astro — 프로젝트 figure: 「자기참조와 마음의 가능성」 논문 (TRIH · 이상한 고리)
//   출처 패턴: _reference/index_v2_live.html L944-959. 색 전량 토큰화, aria-hidden.
interface Props { class?: string }
const { class: className = '' } = Astro.props;
const uid = 'ft-' + Math.random().toString(36).slice(2, 8);
---
<svg viewBox="0 0 400 300" class={`pf-fig ${className}`} aria-hidden="true" focusable="false" preserveAspectRatio="xMidYMid slice">
  <defs>
    <linearGradient id={`${uid}-g`} x1="0" x2="1" y1="0" y2="1">
      <stop offset="0%" style="stop-color:var(--accent);stop-opacity:.16" />
      <stop offset="100%" style="stop-color:var(--violet, #6b5cc4);stop-opacity:.10" />
    </linearGradient>
  </defs>
  <rect width="400" height="300" fill="var(--surface)" />
  <rect width="400" height="300" fill={`url(#${uid}-g)`} />
  {/* 이상한 고리 (figure-8) */}
  <path d="M 100,150 C 100,80 200,80 200,150 C 200,220 300,220 300,150 C 300,80 200,80 200,150 C 200,220 100,220 100,150 Z"
        fill="none" stroke="var(--accent)" stroke-width="2" opacity="0.6" class="ft-loop" />
  <text x="60" y="50" fill="var(--accent)" font-size="11" opacity="0.8"
        style="font-family:var(--font-display-en);font-style:italic;letter-spacing:3px">Self-Reference</text>
  <text x="240" y="284" fill="var(--violet, #6b5cc4)" font-size="11" opacity="0.8"
        style="font-family:var(--font-display-en);font-style:italic;letter-spacing:3px">→ Emergence</text>
  <text x="200" y="158" text-anchor="middle" fill="var(--accent)" font-size="26"
        style="font-family:var(--font-display-en);font-style:italic;font-weight:600;letter-spacing:2px">TRIH</text>
</svg>
<style>
  .pf-fig{display:block;width:100%;height:100%}
  .ft-loop{stroke-dasharray:4 6;animation:ft-dash 30s linear infinite}
  @keyframes ft-dash{to{stroke-dashoffset:-1000}}
  @media (prefers-reduced-motion: reduce){.ft-loop{animation:none !important}}
</style>
