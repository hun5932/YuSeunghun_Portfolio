---
// ═══════════════════════════════════════════════════════════════════════════
// TrihDiagram.astro — TRIH 4영역 동형성 다이어그램(정적)
//   출처 패턴: _reference/index_v2_live.html L694-774 (reh 4-node isomorphism map)
//   · 4노드: 시각(에셔·상) / 청각(바흐·우) / 논리(괴델·하) / 계산(트랜스포머·좌)
//   · 중심 = 자기참조 코어(TRIH). 노드간 동형 연결선 + 대각선.
//   · 하드코딩 색(#806832 gold / #4a3d96 violet) → var(--accent) / var(--violet,폴백) 토큰화.
//   · 정적·비상호작용(role=img). 클릭 인스펙터가 필요하면 islands/TrihInspector.astro 사용.
// props:
//   locale : aria-label 언어 (기본 'ko')
//   class  : 배치 유틸 클래스
// ═══════════════════════════════════════════════════════════════════════════
interface Props {
  locale?: 'ko' | 'en';
  class?: string;
}
const { locale = 'ko', class: className = '' } = Astro.props;
const uid = 'td-' + Math.random().toString(36).slice(2, 8);
const label =
  locale === 'ko'
    ? 'TRIH 4영역 동형성 다이어그램 — 에셔·바흐·괴델·트랜스포머'
    : 'TRIH four-domain isomorphism diagram — Escher, Bach, Gödel, Transformer';

// 노드 정의 (좌표·도메인 라벨·인물·섹션 태그). 색축: gold=시각/청각, violet=논리/계산.
const nodes = [
  { cx: 250, cy: 80,  dom: 'VISUAL',   fig: 'Escher',      sec: '§3', axis: 'gold'   },
  { cx: 420, cy: 250, dom: 'AUDITORY', fig: 'Bach',        sec: '§4', axis: 'gold'   },
  { cx: 250, cy: 420, dom: 'LOGIC',    fig: 'Gödel',       sec: '§5', axis: 'violet' },
  { cx: 80,  cy: 250, dom: 'COMPUTE',  fig: 'Transformer', sec: '§6', axis: 'violet' },
] as const;
const stroke = (axis: string) => (axis === 'gold' ? 'var(--accent)' : 'var(--violet, #6b5cc4)');
---

<svg viewBox="0 0 500 500" class={`trih-diagram ${className}`} role="img" aria-label={label}>
  <defs>
    <linearGradient id={`${uid}-g`} x1="0" x2="1" y1="0" y2="1">
      <stop offset="0%" style="stop-color:var(--accent)" />
      <stop offset="100%" style="stop-color:var(--violet, #6b5cc4)" />
    </linearGradient>
  </defs>

  {/* 가이드 링 */}
  <g opacity="0.3">
    <circle cx="250" cy="250" r="190" fill="none" stroke="var(--border)" stroke-width="1" stroke-dasharray="2 6" />
    <circle cx="250" cy="250" r="130" fill="none" stroke="var(--border)" stroke-width="1" />
  </g>

  {/* 동형성 연결 곡선(노드 간) */}
  <g opacity="0.6" stroke-linecap="round">
    <path d="M 250,80 Q 350,150 420,250" fill="none" stroke={`url(#${uid}-g)`} stroke-width="1.2" stroke-dasharray="3 6" />
    <path d="M 420,250 Q 350,350 250,420" fill="none" stroke={`url(#${uid}-g)`} stroke-width="1.2" stroke-dasharray="3 6" />
    <path d="M 250,420 Q 150,350 80,250" fill="none" stroke={`url(#${uid}-g)`} stroke-width="1.2" stroke-dasharray="3 6" />
    <path d="M 80,250 Q 150,150 250,80" fill="none" stroke={`url(#${uid}-g)`} stroke-width="1.2" stroke-dasharray="3 6" />
  </g>

  {/* 대각 교차선 */}
  <g opacity="0.25">
    <line x1="250" y1="80" x2="250" y2="420" stroke="var(--accent)" stroke-width="0.8" stroke-dasharray="1 4" />
    <line x1="80" y1="250" x2="420" y2="250" stroke="var(--accent)" stroke-width="0.8" stroke-dasharray="1 4" />
  </g>

  {/* 자기참조 코어 */}
  <g>
    <circle cx="250" cy="250" r="58" fill="var(--bg)" stroke="var(--accent)" stroke-width="1.5" />
    <circle cx="250" cy="250" r="48" fill="none" stroke="var(--accent)" stroke-width="0.5" stroke-dasharray="2 4" class="td-spin" style="transform-origin:250px 250px" />
    <text x="250" y="243" text-anchor="middle" fill="var(--accent)" font-size="15"
          style="font-family:var(--font-display-en);font-style:italic;letter-spacing:1px">TRIH</text>
    <text x="250" y="265" text-anchor="middle" fill="var(--ink-3)" font-size="8" letter-spacing="1.5">RECURSIVE</text>
    <text x="250" y="276" text-anchor="middle" fill="var(--ink-3)" font-size="8" letter-spacing="1.5">EMERGENCE</text>
  </g>

  {/* 4 도메인 노드 */}
  {nodes.map((n) => (
    <g>
      <circle cx={n.cx} cy={n.cy} r="40" fill="var(--surface)" stroke={stroke(n.axis)} stroke-width="2" />
      <text x={n.cx} y={n.cy - 4} text-anchor="middle" fill={stroke(n.axis)} font-size="11"
            style="font-family:var(--font-display-en);letter-spacing:2px">{n.dom}</text>
      <text x={n.cx} y={n.cy + 12} text-anchor="middle" fill="var(--ink)" font-size="11"
            style="font-family:var(--font-body);font-weight:500">{n.fig}</text>
      <text x={n.cx} y={n.cy < 250 ? n.cy - 48 : n.cy + 58} text-anchor="middle" fill="var(--ink-3)" font-size="9" letter-spacing="1.5">SEC {n.sec}</text>
    </g>
  ))}
</svg>

<style>
  .trih-diagram { display: block; width: 100%; height: auto; }
  .td-spin { animation: td-rot 26s linear infinite; }
  @keyframes td-rot { to { transform: rotate(360deg); } }
  @media (prefers-reduced-motion: reduce) {
    .td-spin { animation: none !important; }
  }
</style>
