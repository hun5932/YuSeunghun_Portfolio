---
// ═══════════════════════════════════════════════════════════════════════════
// FigDrosteV2.astro — 히어로 로테이터 2번째 레이어 (v2 원본 드로스테 충실 재현)
//   출처: _reference/YuSeunghun_Portfolio_v2.html L1215-1288 drawDroste() 정독 이식.
//   원본 상수 그대로: S=0.74 · TH=-6.5° · CX=CY=260 · viewBox 520 정방형.
//   · 중첩 액자 N=10층 — 각 층 scale 0.74ⁱ · rotate(-6.5°·i) 누적(자기유사 재귀).
//   · 각 액자에 4도메인 라벨 'PL.0n · {도메인}' 주기 반복(mod 4) — 색축 gold/violet.
//   · 도메인별 미니 글리프: 시각=그림속그림 / 청각=파형 / 논리=⌜G⌝ / 계산=하삼각 마스크.
//   · 액자 네 모서리를 잇는 로그 나선 4가닥(닮음변환 불변곡선, non-scaling-stroke).
//   · 중심 소실점 라디얼 안개(위치 고정, --bg) + 중앙 하삼각 인과 마스크(--accent).
//   · 이음새 없는 무한 줌: .zoom 그룹 scale 1→0.74⁻⁴(3.3354)·rotate 0→26° 48s 선형 반복.
//     한 주기 = 4단계(시각→청각→논리→계산) 전체라 라벨·색·획폭 자기유사 정렬 → 이음매 무.
//   · 빌드타임 정적 SVG(런타임 JS 0 — 프론트매터 배열 map). CSS @keyframes 만. reduced-motion 정지.
// props:
//   locale : 라벨 언어 (기본 'ko') — 'ko' 시각/청각/논리/계산, 'en' VISUAL…
//   class  : 배치용 유틸 클래스 패스스루
// ═══════════════════════════════════════════════════════════════════════════
interface Props {
  locale?: 'ko' | 'en';
  class?: string;
}
const { locale = 'ko', class: className = '' } = Astro.props;
// 고유 id 프리픽스 — 한 페이지 다중 인스턴스 clip/gradient 충돌 방지
const uid = 'fdv2-' + Math.random().toString(36).slice(2, 8);

// ── 재귀 파라미터 (v2 원본 상수) ──
const S = 0.74;    // 층당 축소율
const TH = -6.5;   // 층당 회전(도)
const N = 10;      // 중첩 액자 수 (원본 20 → 로테이터용 10, 소실점 안개가 최심층 은폐)
const CX = 260;
const CY = 260;

// 4 도메인 라벨 순환 + 색축 (gold=시각/청각, violet=논리/계산)
const DOM_KO = ['시각', '청각', '논리', '계산'] as const;
const DOM_EN = ['VISUAL', 'AUDITORY', 'LOGIC', 'COMPUTE'] as const;
const doms = locale === 'ko' ? DOM_KO : DOM_EN;
const axisGold = [true, true, false, false]; // 인덱스별 gold 여부
const col = (i: number) => (axisGold[i % 4] ? 'var(--accent)' : 'var(--violet, #6b5cc4)');
// [fig-droste-label-contrast] 라벨 텍스트 전용 색 — 라이트모드에서 골드(--accent #806832)가
// 얇은 13px 캡스로 한지 위 대비 미달('PL.0n' 판독 불가) → 소형텍스트 전용 진한 골드
// (--accent-text #6B5429)로 교체. 다크모드는 --accent-text 가 밝은 금을 상속하므로 무변(양호 유지).
const labelCol = (i: number) => (axisGold[i % 4] ? 'var(--accent-text, var(--accent))' : 'var(--violet, #6b5cc4)');

// 계산 도메인 글리프 — 하삼각 인과 마스크(원본 GLYPH[3], x444/y44 기준, 셀 6.4 간격)
const glyphMask: { x: number; y: number }[] = [];
for (let r = 0; r < 4; r++)
  for (let q = 0; q <= r; q++)
    glyphMask.push({ x: +(444 + q * 6.4).toFixed(2), y: +(44 + r * 6.4).toFixed(2) });

// 중첩 액자 N층 — 바깥(i=0)이 위에 오도록 i=N-1 → 0 순으로 페인트
const frames = Array.from({ length: N }, (_, k) => {
  const i = N - 1 - k;
  return {
    i,
    s: +Math.pow(S, i).toFixed(6),   // 누적 축소율 0.74ⁱ
    rot: +(TH * i).toFixed(2),        // 누적 회전 -6.5°·i
    color: col(i),
    labelColor: labelCol(i),           // 라벨 텍스트 전용(라이트 대비 보강)
    g: i % 4,                          // 글리프/도메인 인덱스
    label: `PL.0${(i % 4) + 1} · ${doms[i % 4]}`,
  };
});

// ── 로그 나선 4가닥 — 액자 네 모서리의 궤적(닮음변환 T의 불변곡선) ──
const rad = (TH * Math.PI) / 180;
// T: 중심 기준 scale S · rotate TH  (안쪽으로 한 층)
const T = ([x, y]: number[]) => {
  const dx = x - CX, dy = y - CY;
  return [
    CX + S * (dx * Math.cos(rad) - dy * Math.sin(rad)),
    CY + S * (dx * Math.sin(rad) + dy * Math.cos(rad)),
  ];
};
// Tinv: 역변환 (바깥으로 한 층)
const Tinv = ([x, y]: number[]) => {
  const r2 = (-TH * Math.PI) / 180, dx = (x - CX) / S, dy = (y - CY) / S;
  return [
    CX + dx * Math.cos(r2) - dy * Math.sin(r2),
    CY + dx * Math.sin(r2) + dy * Math.cos(r2),
  ];
};
const corners = [[30, 30], [490, 30], [490, 490], [30, 490]];
const spirals = corners.map((c0, k) => {
  let p = c0;
  for (let j = 0; j < 5; j++) p = Tinv(p);           // 바깥으로 5겹 외삽
  const pts = [p];
  for (let j = 0; j < N + 9; j++) { p = T(p); pts.push(p); } // 소실점 향해 수렴
  const d = 'M' + pts.map((q) => `${q[0].toFixed(1)} ${q[1].toFixed(1)}`).join(' L');
  return { d, color: col(k) };
});

// ── 소실점 중심 하삼각 인과 마스크(위치 고정, 원본 centerMask) ──
const centerMask: { x: number; y: number }[] = [];
for (let r = 0; r < 5; r++)
  for (let q = 0; q <= r; q++)
    centerMask.push({ x: +(q * 4.4).toFixed(2), y: +(r * 4.4).toFixed(2) });
---

<div class={`fig-drostev2 ${className}`} aria-hidden="true">
  <svg viewBox="0 0 520 520" class="fig-drostev2-svg" focusable="false">
    <defs>
      <clipPath id={`${uid}-clip`}><rect x="0" y="0" width="520" height="520" /></clipPath>
      {/* 소실점 안개 — 위치 고정 라디얼(--bg), 최심 액자 빈 슬롯 은폐 */}
      {/* [fig-droste-center-clean] 소실점 veil 강화 — 라이트모드에서 최심 액자 뭉침이
          디더링/렌더 아티팩트처럼 읽히던 중심부를 더 깨끗이 덮는다. veil 은 centerMask(초점
          글리프)보다 뒤에 페인트되므로 초점은 선명하게 남고 뒤엉킨 프레임만 정리된다. */}
      <radialGradient id={`${uid}-mist`} cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="var(--bg)" stop-opacity="0.9" />
        <stop offset="38%" stop-color="var(--bg)" stop-opacity="0.5" />
        <stop offset="74%" stop-color="var(--bg)" stop-opacity="0" />
      </radialGradient>
      {/* [fig-droste-weight] 이 프레임 한정 미세 면채움 — 얇은 라인아트의 좌우 시각 무게 보강.
          저강도 accent-tint 라디얼(시맨틱 토큰 --accent), 줌 그룹 뒤 배경에 위치 고정.
          최소 강도라 80px 볼드 헤드라인을 압도하지 않는다. reduced-motion/크로스페이드 불변. */}
      <radialGradient id={`${uid}-glow`} cx="50%" cy="50%" r="60%">
        <stop offset="0%" stop-color="var(--accent)" stop-opacity="0.11" />
        <stop offset="55%" stop-color="var(--accent)" stop-opacity="0.05" />
        <stop offset="100%" stop-color="var(--accent)" stop-opacity="0" />
      </radialGradient>
    </defs>

    <g clip-path={`url(#${uid}-clip)`}>
      {/* [fig-droste-weight] 배경 면채움 — 줌과 무관하게 고정, 프레임 라인 사이로 은은한 골드 무게 */}
      <rect x="0" y="0" width="520" height="520" fill={`url(#${uid}-glow)`} />
      {/* 무한 줌 그룹 — 나선 + 액자군이 함께 확대(48s, 4스텝). transform-origin=소실점 */}
      <g class="fdv2-zoom" style="transform-origin:260px 260px">
        {/* 로그 나선 4가닥 (non-scaling-stroke → 어느 줌에서도 1px) */}
        {spirals.map((sp) => (
          <path d={sp.d} fill="none" stroke={sp.color} stroke-width="1"
                vector-effect="non-scaling-stroke" opacity="0.3" />
        ))}
        {/* 중첩 액자 N층 — 각 층 라벨 + 도메인 글리프 */}
        {frames.map((f) => (
          <g transform={`translate(260,260) scale(${f.s}) rotate(${f.rot}) translate(-260,-260)`}>
            <rect x="30" y="30" width="460" height="460" fill="none" stroke={f.color} stroke-width="1.7" />
            <text x="44" y="21" fill={f.labelColor} font-size="13" letter-spacing="1.6"
                  style="font-family:var(--font-mono);text-rendering:geometricPrecision;font-synthesis:none">{f.label}</text>
            {/* 시각 — 그림 속 그림 */}
            {f.g === 0 && (
              <g stroke={f.color} fill="none" stroke-width="1.5">
                <rect x="444" y="44" width="26" height="26" />
                <rect x="451" y="51" width="12" height="12" />
              </g>
            )}
            {/* 청각 — 파형 */}
            {f.g === 1 && (
              <path d="M444 57 q7 -14 13 0 q7 14 13 0" stroke={f.color} fill="none" stroke-width="1.6" />
            )}
            {/* 논리 — 자기지시 ⌜G⌝ */}
            {f.g === 2 && (
              <text x="444" y="66" font-size="17" font-weight="700" fill={f.color}
                    style="font-family:var(--font-mono)">⌜G⌝</text>
            )}
            {/* 계산 — 하삼각 인과 마스크 */}
            {f.g === 3 && glyphMask.map((m) => (
              <rect x={m.x} y={m.y} width="5" height="5" fill={f.color} />
            ))}
          </g>
        ))}
      </g>

      {/* 소실점 안개(위치 고정 — 줌과 무관) */}
      <rect x="0" y="0" width="520" height="520" fill={`url(#${uid}-mist)`} />

      {/* 중앙 하삼각 인과 마스크 — 모든 깊이의 끝에 놓인 표식(정적) */}
      <g transform="translate(249.5,249.5)" opacity="0.62">
        {centerMask.map((m) => (
          <rect x={m.x} y={m.y} width="3.4" height="3.4" fill="var(--accent)" />
        ))}
      </g>
    </g>
  </svg>

  {/* 하단 캡션 pill — FigOrbit/FigDroste 와 동일 리듬 */}
  <div class="fdv2-caption">
    <span>Print&nbsp;Gallery&nbsp;·&nbsp;Recursive&nbsp;Frame</span>
  </div>
</div>

<style>
  .fig-drostev2 {
    position: relative;
    width: 100%;
    max-width: 420px;
    margin-inline: auto;
    aspect-ratio: 1 / 1;
  }
  .fig-drostev2-svg { display: block; width: 100%; height: 100%; }

  /* 하단 캡션 pill */
  .fdv2-caption {
    position: absolute;
    left: 50%;
    bottom: 4%;
    transform: translateX(-50%);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 7px 16px;
    white-space: nowrap;
    box-shadow: 0 2px 12px rgb(0 0 0 / 0.06);
  }
  .fdv2-caption span {
    font-family: var(--font-mono);
    font-size: var(--fz-xxs);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent-text, var(--accent));
  }

  /* 이음새 없는 무한 줌 — scale 1→0.74⁻⁴(3.3354)·rotate 0→26°, 48s 선형 무한 반복 */
  .fdv2-zoom { animation: fdv2-zoom 48s linear infinite; }
  @keyframes fdv2-zoom {
    from { transform: scale(1) rotate(0deg); }
    to   { transform: scale(3.3354) rotate(26deg); }
  }

  /* hover 가속(선택) — 모션 허용 시에만 */
  @media (prefers-reduced-motion: no-preference) {
    .fig-drostev2:hover .fdv2-zoom { animation-duration: 12s; }
  }

  /* 절대 규칙: 모션 최소화 선호 시 줌 정지 */
  @media (prefers-reduced-motion: reduce) {
    .fdv2-zoom { animation: none !important; }
  }
</style>
