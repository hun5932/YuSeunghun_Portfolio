---
// FigCetana.astro — 프로젝트 figure: CETANA 옻칠나전 브랜드 (기물 실루엣 + 나전 패턴)
//   출처 패턴: _reference/index_v2_live.html L987-1007. 색 전량 토큰화, aria-hidden.
interface Props { class?: string }
const { class: className = '' } = Astro.props;
const uid = 'fc-' + Math.random().toString(36).slice(2, 8);
---
<svg viewBox="0 0 400 300" class={`pf-fig ${className}`} aria-hidden="true" focusable="false" preserveAspectRatio="xMidYMid slice">
  <defs>
    <linearGradient id={`${uid}-g`} x1="0" x2="1" y1="1" y2="0">
      <stop offset="0%" style="stop-color:var(--ink);stop-opacity:.10" />
      <stop offset="100%" style="stop-color:var(--accent);stop-opacity:.22" />
    </linearGradient>
    <pattern id={`${uid}-najeon`} width="20" height="20" patternUnits="userSpaceOnUse">
      <circle cx="10" cy="10" r="1.5" fill="var(--accent-2)" opacity="0.4" />
      <circle cx="0" cy="0" r="0.8" fill="var(--accent)" opacity="0.3" />
      <circle cx="20" cy="20" r="0.8" fill="var(--accent)" opacity="0.3" />
    </pattern>
  </defs>
  <rect width="400" height="300" fill="var(--surface)" />
  <rect width="400" height="300" fill={`url(#${uid}-g)`} />
  <rect width="400" height="300" fill={`url(#${uid}-najeon)`} />
  {/* 기물(그릇) 실루엣 */}
  <path d="M 150,180 C 150,150 170,140 200,140 C 230,140 250,150 250,180 L 245,230 C 245,245 235,255 200,255 C 165,255 155,245 155,230 Z"
        fill="var(--surface-2)" stroke="var(--accent)" stroke-width="1.5" />
  <ellipse cx="200" cy="180" rx="50" ry="5" fill="none" stroke="var(--accent-2)" stroke-width="0.8" opacity="0.6" />
  <text x="200" y="100" text-anchor="middle" fill="var(--accent-2)" font-size="28"
        style="font-family:var(--font-display-en);font-style:italic;font-weight:500;letter-spacing:6px">CETANA</text>
  <text x="200" y="118" text-anchor="middle" fill="var(--accent)" font-size="8" opacity="0.7"
        style="font-family:var(--font-body);letter-spacing:4px">세 · 타 · 나</text>
</svg>
<style>.pf-fig{display:block;width:100%;height:100%}</style>
