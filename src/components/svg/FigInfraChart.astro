---
// FigInfraChart.astro — infra-lab 배포 순단 비포/애프터 재현 차트
//   단일 인스턴스 패치 1.2s vs k8s 롤링 업데이트 0s (무중단) — facts.json INF-01 정합.
//   ※ 스크린샷 흉내 아님: 실측 데이터 기반 '재현 도판'(캡션에 명시).
//   패턴 준수: viewBox 0 0 400 300 · 색 전량 var() 토큰 · uid 프리픽스 충돌 방지.
interface Props { class?: string }
const { class: className = '' } = Astro.props;
const uid = 'fic-' + Math.random().toString(36).slice(2, 8);

// INF-01 실측: before 1.2s → after 0s. 스케일: 1.2s = 132px(막대 최대 높이).
const baseY = 214;      // 막대 하단 기준선
const beforeH = 132;    // 1.2s → 132px (after = 0s → 막대 없음, 무중단 라인으로 표시)
---
<svg viewBox="0 0 400 300" class={`pf-fig ${className}`} role="img"
     aria-label="배포 순단 실측 재현 차트 — 단일 인스턴스 패치 1.2초 vs Kubernetes 롤링 업데이트 0초(무중단)"
     focusable="false" preserveAspectRatio="xMidYMid slice">
  <defs>
    <linearGradient id={`${uid}-b`} x1="0" x2="0" y1="0" y2="1">
      <stop offset="0%" style="stop-color:var(--ink-3);stop-opacity:.55" />
      <stop offset="100%" style="stop-color:var(--ink-3);stop-opacity:.18" />
    </linearGradient>
  </defs>
  <rect width="400" height="300" fill="var(--surface)" />

  {/* y축 기준선 + 0s 그리드 */}
  <line x1="60" y1={baseY} x2="360" y2={baseY} stroke="var(--border)" stroke-width="1" />
  <text x="52" y={baseY + 3} text-anchor="end" fill="var(--ink-3)" font-size="8"
        style="font-family:var(--font-mono)">0s</text>
  <line x1="60" y1={baseY - beforeH} x2="360" y2={baseY - beforeH} stroke="var(--border-soft, var(--border))"
        stroke-width="0.7" stroke-dasharray="2 4" opacity="0.6" />
  <text x="52" y={baseY - beforeH + 3} text-anchor="end" fill="var(--ink-3)" font-size="8"
        style="font-family:var(--font-mono)">1.2s</text>

  {/* BEFORE — 단일 인스턴스 패치: 순단 1.2s */}
  <rect x="112" y={baseY - beforeH} width="72" height={beforeH} rx="2" fill={`url(#${uid}-b)`}
        stroke="var(--ink-3)" stroke-width="1" opacity="0.9" />
  <text x="148" y={baseY - beforeH - 10} text-anchor="middle" fill="var(--ink-2)" font-size="15"
        style="font-family:var(--font-mono);font-weight:600">1.2s</text>
  <text x="148" y={baseY + 18} text-anchor="middle" fill="var(--ink-3)" font-size="9"
        style="font-family:var(--font-mono)">single instance</text>
  <text x="148" y={baseY + 30} text-anchor="middle" fill="var(--ink-3)" font-size="8" opacity="0.8"
        style="font-family:var(--font-mono)">patch → restart</text>

  {/* AFTER — k8s 롤링: 무중단 0s (막대 없음, 무중단 라인으로 표시) */}
  <rect x="248" y={baseY - 3} width="72" height="3" rx="1.5" fill="var(--accent)" opacity="0.9" />
  <circle cx="284" cy={baseY - 1.5} r="4" fill="var(--accent)" class="fic-pulse" />
  <text x="284" y={baseY - 16} text-anchor="middle" fill="var(--accent)" font-size="15"
        style="font-family:var(--font-mono);font-weight:600">0s</text>
  <text x="284" y={baseY + 18} text-anchor="middle" fill="var(--accent)" font-size="9"
        style="font-family:var(--font-mono)">k8s rolling</text>
  <text x="284" y={baseY + 30} text-anchor="middle" fill="var(--accent)" font-size="8" opacity="0.85"
        style="font-family:var(--font-mono)">maxUnavailable: 0</text>

  {/* 개선 화살표 1.2s → 0s (상단 헤더 — 막대 값 라벨 y=72와 겹치지 않도록 위로 배치) */}
  <text x="200" y="38" text-anchor="middle" fill="var(--accent)" font-size="12"
        style="font-family:var(--font-display-en);font-style:italic;letter-spacing:1px">downtime 1.2s → 0s</text>
  <text x="200" y="52" text-anchor="middle" fill="var(--measure, var(--accent))" font-size="8.5" opacity="0.85"
        style="font-family:var(--font-mono);letter-spacing:1px">zero-downtime · measured</text>

  {/* 재현 도판 명시 (스크린샷 흉내 금지) */}
  <text x="200" y="290" text-anchor="middle" fill="var(--ink-3)" font-size="8" opacity="0.7"
        style="font-family:var(--font-mono);letter-spacing:1px">실측 데이터 기반 재현 도판 · reconstructed from measured data</text>
</svg>
<style>
  .pf-fig{display:block;width:100%;height:100%}
  .fic-pulse{animation:fic-pulse 2.4s ease-in-out infinite}
  @keyframes fic-pulse{0%,100%{opacity:.9}50%{opacity:.35}}
  @media (prefers-reduced-motion: reduce){.fic-pulse{animation:none !important}}
</style>
