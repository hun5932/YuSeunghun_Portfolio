---
// FigHobbybuddy.astro — 프로젝트 figure: HobbyBuddy(취미랑) — 매칭 그래프
//   출처 패턴: _reference/index_v2_live.html L1034-1055. 색 전량 토큰화, aria-hidden.
interface Props { class?: string }
const { class: className = '' } = Astro.props;
const uid = 'fh-' + Math.random().toString(36).slice(2, 8);
---
<svg viewBox="0 0 400 300" class={`pf-fig ${className}`} aria-hidden="true" focusable="false" preserveAspectRatio="xMidYMid slice">
  <defs>
    <linearGradient id={`${uid}-g`} x1="0" x2="1" y1="0" y2="1">
      <stop offset="0%" style="stop-color:var(--violet, #6b5cc4);stop-opacity:.16" />
      <stop offset="100%" style="stop-color:var(--accent);stop-opacity:.08" />
    </linearGradient>
  </defs>
  <rect width="400" height="300" fill="var(--surface)" />
  <rect width="400" height="300" fill={`url(#${uid}-g)`} />
  {/* 매칭 노드 그래프 */}
  <g stroke="var(--accent)" stroke-width="0.8" opacity="0.5">
    <line x1="100" y1="120" x2="200" y2="80" /><line x1="200" y1="80" x2="300" y2="130" />
    <line x1="100" y1="120" x2="150" y2="200" /><line x1="150" y1="200" x2="280" y2="220" />
    <line x1="300" y1="130" x2="280" y2="220" />
  </g>
  <g>
    <circle cx="100" cy="120" r="14" fill="var(--violet, #6b5cc4)" opacity="0.5" />
    <circle cx="200" cy="80" r="14" fill="var(--accent)" opacity="0.5" />
    <circle cx="300" cy="130" r="14" fill="var(--violet, #6b5cc4)" opacity="0.5" />
    <circle cx="150" cy="200" r="14" fill="var(--accent)" opacity="0.5" />
    <circle cx="280" cy="220" r="14" fill="var(--violet, #6b5cc4)" opacity="0.5" />
  </g>
  <text x="200" y="272" text-anchor="middle" fill="var(--violet, #6b5cc4)" font-size="20" opacity="0.6"
        style="font-family:var(--font-display-en);font-style:italic">HobbyBuddy</text>
</svg>
<style>.pf-fig{display:block;width:100%;height:100%}</style>
