---
// FigJiksats.astro — 프로젝트 figure: JiksaTS Master AI (사찰 + 신경망)
//   출처 패턴: _reference/index_v2_live.html L852-874. 색 전량 토큰화, aria-hidden.
interface Props { class?: string }
const { class: className = '' } = Astro.props;
const uid = 'fj-' + Math.random().toString(36).slice(2, 8);
---
<svg viewBox="0 0 400 300" class={`pf-fig ${className}`} aria-hidden="true" focusable="false" preserveAspectRatio="xMidYMid slice">
  <defs>
    <linearGradient id={`${uid}-g`} x1="0" x2="1" y1="0" y2="1">
      <stop offset="0%" style="stop-color:var(--accent);stop-opacity:.18" />
      <stop offset="100%" style="stop-color:var(--violet, #6b5cc4);stop-opacity:.10" />
    </linearGradient>
  </defs>
  <rect width="400" height="300" fill="var(--surface)" />
  <rect width="400" height="300" fill={`url(#${uid}-g)`} />
  {/* 사찰 지붕 실루엣 */}
  <path d="M 100,180 L 200,120 L 300,180 L 280,180 L 200,135 L 120,180 Z" fill="none" stroke="var(--accent)" stroke-width="1.5" opacity="0.6" />
  <rect x="130" y="180" width="140" height="50" fill="none" stroke="var(--accent)" stroke-width="1" opacity="0.5" />
  {/* 신경망 노드 */}
  <g fill="var(--accent)" opacity="0.7">
    <circle cx="50" cy="60" r="2" /><circle cx="80" cy="80" r="2" /><circle cx="50" cy="100" r="2" />
    <circle cx="350" cy="60" r="2" /><circle cx="320" cy="80" r="2" /><circle cx="350" cy="100" r="2" />
  </g>
  <g stroke="var(--accent)" stroke-width="0.5" opacity="0.4">
    <line x1="50" y1="60" x2="80" y2="80" /><line x1="80" y1="80" x2="50" y2="100" /><line x1="50" y1="60" x2="50" y2="100" />
  </g>
  <text x="200" y="262" text-anchor="middle" fill="var(--accent)" font-size="22" opacity="0.55"
        style="font-family:var(--font-display-en);font-style:italic">JiksaTS</text>
</svg>
<style>.pf-fig{display:block;width:100%;height:100%}</style>
