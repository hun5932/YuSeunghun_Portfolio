---
// FigAiperso.astro — 프로젝트 figure: 마음들이 (AI PERSO) — 마음/대화 모티프
//   출처 패턴: _reference/index_v2_live.html L902-917. 색 전량 토큰화, aria-hidden.
interface Props { class?: string }
const { class: className = '' } = Astro.props;
const uid = 'fp-' + Math.random().toString(36).slice(2, 8);
---
<svg viewBox="0 0 400 300" class={`pf-fig ${className}`} aria-hidden="true" focusable="false" preserveAspectRatio="xMidYMid slice">
  <defs>
    <radialGradient id={`${uid}-g`} cx="50%" cy="50%">
      <stop offset="0%" style="stop-color:var(--violet, #6b5cc4);stop-opacity:.20" />
      <stop offset="100%" style="stop-color:var(--surface);stop-opacity:1" />
    </radialGradient>
  </defs>
  <rect width="400" height="300" fill="var(--surface)" />
  <rect width="400" height="300" fill={`url(#${uid}-g)`} />
  {/* 마음(하트) 유기 곡선 */}
  <path d="M 200,200 C 150,150 100,170 130,110 C 150,80 200,90 200,140 C 200,90 250,80 270,110 C 300,170 250,150 200,200 Z"
        fill="none" stroke="var(--violet, #6b5cc4)" stroke-width="1.5" opacity="0.7" />
  {/* 대화 말풍선 */}
  <rect x="60" y="60" width="60" height="35" rx="8" fill="var(--violet, #6b5cc4)" opacity="0.28" />
  <rect x="280" y="220" width="60" height="35" rx="8" fill="var(--accent)" opacity="0.28" />
  <text x="200" y="272" text-anchor="middle" fill="var(--violet, #6b5cc4)" font-size="20" opacity="0.6"
        style="font-family:var(--font-display-en);font-style:italic">마음들이</text>
</svg>
<style>.pf-fig{display:block;width:100%;height:100%}</style>
