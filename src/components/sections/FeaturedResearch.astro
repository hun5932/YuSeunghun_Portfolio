<script>
  // ── 케이스 색인 상호작용 (ARIA tabs · 크로스페이드는 CSS opacity 130ms) ──
  //   click / mouseenter(hover:hover 매체) / ↑↓ 화살표 · Home/End.
  //   패널은 오버레이 그리드로 겹쳐 있어 전환 시 높이가 고정된다(점프 없음).
  const idx = document.querySelector<HTMLElement>('[data-fr-index]');
  if (idx) {
    const tabs = Array.from(idx.querySelectorAll<HTMLButtonElement>('.fr-row'));
    const panels = Array.from(idx.querySelectorAll<HTMLElement>('.fr-panel'));
    const canHover = window.matchMedia('(hover: hover) and (pointer: fine)');

    const 활성화 = (key: string, focus = false) => {
      tabs.forEach((tab) => {
        const on = tab.dataset.key === key;
        tab.setAttribute('aria-selected', String(on));
        tab.tabIndex = on ? 0 : -1;
        if (on && focus) tab.focus();
      });
      panels.forEach((panel) => {
        panel.classList.toggle('is-active', panel.dataset.panel === key);
      });
    };

    // hover intent 디바운스(70ms · 60~80ms 대역) — 마우스 스윕 시 연쇄 전환(플리커) 억제.
    //   잠깐 스쳐가는 행은 무시하고 '머문' 행만 활성화. click/키보드는 즉시(디바운스 취소).
    let hoverTimer: number | undefined;
    const HOVER_INTENT = 70;
    const clearHover = () => {
      if (hoverTimer !== undefined) { window.clearTimeout(hoverTimer); hoverTimer = undefined; }
    };

    tabs.forEach((tab, i) => {
      tab.addEventListener('click', () => { clearHover(); 활성화(tab.dataset.key || ''); });
      // hover 매체에서만 마우스오버로 미리 열기(터치 오작동 방지) — intent 지연 후 활성화.
      tab.addEventListener('mouseenter', () => {
        if (!canHover.matches) return;
        clearHover();
        hoverTimer = window.setTimeout(() => 활성화(tab.dataset.key || ''), HOVER_INTENT);
      });
      tab.addEventListener('mouseleave', clearHover);
      tab.addEventListener('keydown', (e) => {
        let next = -1;
        if (e.key === 'ArrowDown') next = (i + 1) % tabs.length;
        else if (e.key === 'ArrowUp') next = (i - 1 + tabs.length) % tabs.length;
        else if (e.key === 'Home') next = 0;
        else if (e.key === 'End') next = tabs.length - 1;
        if (next >= 0) {
          e.preventDefault();
          활성화(tabs[next].dataset.key || '', true);
        }
      });
    });
  }
</script>
